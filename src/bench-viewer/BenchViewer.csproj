<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>$(BenchmarkTargetFramework)</TargetFramework>
    <DashName>bench-viewer</DashName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <WasmFingerprintAssets>true</WasmFingerprintAssets>
    <BlazorFingerprintBlazorJs>true</BlazorFingerprintBlazorJs>
    <CompressionEnabled>false</CompressionEnabled>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="$(MicrosoftAspNetCoreVersion)" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="$(MicrosoftAspNetCoreVersion)" PrivateAssets="all" />
  </ItemGroup>

  <!-- Generate BuildConfig.g.cs with MSBuild properties available at runtime -->
  <Target Name="GenerateBuildConfig" BeforeTargets="CoreCompile">
    <PropertyGroup>
      <_BuildConfigFile>$(IntermediateOutputPath)BuildConfig.g.cs</_BuildConfigFile>
    </PropertyGroup>
    <WriteLinesToFile File="$(_BuildConfigFile)" Overwrite="true" Lines="namespace BenchViewer.Models%3B;internal static class BuildConfig;{;    public const string GitHubRepo = &quot;$(GitHubRepo)&quot;%3B;}" />
    <ItemGroup>
      <Compile Include="$(_BuildConfigFile)" />
    </ItemGroup>
  </Target>

  <!-- TypeScript compilation -->
  <PropertyGroup>
    <TypeScriptOutputDir>wwwroot\chart</TypeScriptOutputDir>
    <NpmInstallStamp>node_modules/.install-stamp</NpmInstallStamp>
  </PropertyGroup>

  <ItemGroup>
    <TypeScriptSource Include="chart\**\*.ts" />
    <None Remove="chart\**" />
  </ItemGroup>

  <Target Name="NpmInstall" BeforeTargets="CompileTypeScript" Inputs="package.json" Outputs="$(NpmInstallStamp)">
    <Exec Command="npm install" WorkingDirectory="$(MSBuildProjectDirectory)" />
    <Touch Files="$(NpmInstallStamp)" AlwaysCreate="true" />
  </Target>

  <Target Name="CompileTypeScript" BeforeTargets="Build" Inputs="@(TypeScriptSource)" Outputs="$(TypeScriptOutputDir)\main.js">
    <Exec Command="npx tsc" WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>

</Project>
