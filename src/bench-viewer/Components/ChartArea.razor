@namespace BenchViewer.Components

<div class="charts-area px-3 py-2">
    @foreach (var metric in Metrics)
    {
        <div class="chart-container mb-3">
            <canvas id="chart-@CurrentApp-@metric"></canvas>
        </div>
    }

    @if (Metrics.Count == 0)
    {
        <div class="text-muted p-3">No metrics available for this app.</div>
    }
</div>

@code {
    [Parameter] public string CurrentApp { get; set; } = "";
    [Parameter] public List<string> Metrics { get; set; } = new();
}
