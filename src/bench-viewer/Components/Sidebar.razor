@namespace BenchViewer.Components
@using BenchViewer.Models

<aside class="sidebar">
    <div class="sidebar-header">
        <div>
            <div class="sidebar-title">.NET WASM Macro Benchmarks</div>
            @if (!string.IsNullOrEmpty(LastUpdated))
            {
                <div class="sidebar-updated">
                    <a href="https://github.com/Blazor-Playground/macro-benchmarks/actions/workflows/benchmark.yml" target="_blank" rel="noopener">Updated @SelectedPointInfo.FormatDate(LastUpdated)</a>
                </div>
            }
        </div>
        <a href="https://github.com/Blazor-Playground/macro-benchmarks" target="_blank" rel="noopener" title="GitHub Repository">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
        </a>
    </div>
    <div class="sidebar-body">
        <div class="px-3 py-2 border-bottom">
            <div class="form-check form-check-sm">
                <input class="form-check-input" type="checkbox" id="show-releases"
                       checked="@ShowReleases"
                       @onchange="e => OnShowReleasesChanged.InvokeAsync((bool)e.Value!)" />
                <label class="form-check-label small" for="show-releases">
                    Show GA releases
                </label>
            </div>
            <div class="form-check form-check-sm mt-1">
                <input class="form-check-input" type="checkbox" id="show-daily-releases"
                       checked="@ShowDailyReleases"
                       @onchange="e => OnShowDailyReleasesChanged.InvokeAsync((bool)e.Value!)" />
                <label class="form-check-label small" for="show-daily-releases">
                    Show daily releases
                </label>
            </div>
        </div>
        <FilterPanel FilterGroups="@FilterGroups"
                     CheckedValues="@CheckedValues"
                     CurrentApp="@CurrentApp"
                     OnFilterChanged="@OnFilterChanged" />
    </div>
</aside>

@code {
    [Parameter] public string LastUpdated { get; set; } = "";
    [Parameter] public bool ShowReleases { get; set; }
    [Parameter] public bool ShowDailyReleases { get; set; }
    [Parameter] public Dictionary<string, List<string>> FilterGroups { get; set; } = new();
    [Parameter] public Dictionary<string, HashSet<string>> CheckedValues { get; set; } = new();
    [Parameter] public string CurrentApp { get; set; } = "";
    [Parameter] public EventCallback<bool> OnShowReleasesChanged { get; set; }
    [Parameter] public EventCallback<bool> OnShowDailyReleasesChanged { get; set; }
    [Parameter] public EventCallback<(string Group, string Value, bool Checked)> OnFilterChanged { get; set; }
}
