@page "/"
@using BenchViewer.Components
@using BenchViewer.Models
@implements IAsyncDisposable

<PageTitle>.NET WASM Benchmark Dashboard</PageTitle>

@if (viewIndex != null)
{
    <Sidebar LastUpdated="@viewIndex.LastUpdated"
             ShowReleases="@showReleases"
             ShowDailyReleases="@showDailyReleases"
             FilterGroups="@filterGroups"
             CheckedValues="@checkedValues"
             CurrentApp="@currentApp"
             OnShowReleasesChanged="@HandleShowReleasesChanged"
             OnShowDailyReleasesChanged="@HandleShowDailyReleasesChanged"
             OnFilterChanged="@HandleFilterChanged" />
}

<main class="main-content">
    @if (loading)
    {
        <div class="d-flex justify-content-center align-items-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (error != null)
    {
        <div class="alert alert-warning m-3">@error</div>
    }
    else if (viewIndex != null)
    {
        <div class="main-top-bar">
            <div class="tabs-header px-3 pt-3 d-flex justify-content-between align-items-end">
                <AppTabs Apps="@viewIndex.Apps" ActiveApp="@currentApp" OnAppChanged="@HandleAppChanged" />
            </div>
            @if (!string.IsNullOrEmpty(currentApp))
            {
                <div class="app-link-panel">
                    <a href="./apps/@currentApp/" target="_blank" rel="noopener">
                        Open the application published with no-workload preset with the latest daily SDK ↗
                    </a>
                </div>
            }
        </div>
        <ChartArea Metrics="@currentMetrics"
                   CurrentApp="@currentApp" />
    }
    else
    {
        <div class="text-muted p-5 text-center">
            No benchmark data yet. Run the CI pipeline to collect data.
        </div>
    }
</main>

@if (selectedPoint != null)
{
    <DetailPanel CurrentPoint="@selectedPoint"
                 PreviousPoint="@previousPoint"
                 OnClose="@ClearSelection" />
}
